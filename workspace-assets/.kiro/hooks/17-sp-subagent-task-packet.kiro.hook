{
  "enabled": true,
  "name": "SP 17 - Subagent Task Packet Gate",
  "description": "Require Kiro main agent to construct a complete Subagent Task Packet before delegating implementation, verification, spec review, or code review to subagents.",
  "version": "1",
  "when": {
    "type": "preTaskExecution"
  },
  "then": {
    "type": "askAgent",
    "prompt": "Before invoking any sp-* subagent, construct a Subagent Task Packet with spec, requirement, design section, task id, task text, goal, scope, non-goals, allowed files, forbidden files, verification command, expected output, and completion definition. If any required context is missing, mark BLOCKED or NEEDS_CONTEXT and ask for clarification instead of delegating."
  }
}
